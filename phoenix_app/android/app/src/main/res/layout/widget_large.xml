<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FF1A1A1A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PHOENIX"
            android:textColor="#FFFFA726"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LV 1"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Protocol progress -->
    <TextView
        android:id="@+id/tv_protocol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Protocollo: 0/6"
        android:textColor="#FFFFA726"
        android:textSize="13sp"
        android:layout_marginTop="8dp" />

    <!-- Protocol items grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        android:layout_marginTop="4dp">

        <TextView android:id="@+id/tv_sleep" android:text="○ Sonno" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_columnWeight="1" />
        <TextView android:id="@+id/tv_training" android:text="○ Training" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_columnWeight="1" />
        <TextView android:id="@+id/tv_fasting" android:text="○ Digiuno" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_columnWeight="1" />
        <TextView android:id="@+id/tv_cold" android:text="○ Freddo" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_columnWeight="1" />
        <TextView android:id="@+id/tv_meditation" android:text="○ Meditazione" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_columnWeight="1" />
        <TextView android:id="@+id/tv_nutrition" android:text="○ Nutrizione" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_columnWeight="1" />
    </GridLayout>

    <!-- Ring data -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tv_steps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 passi"
            android:textColor="#AAFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_hrv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#AAFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_recovery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#AAFFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Sleep + Next -->
    <TextView
        android:id="@+id/tv_sleep_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AAFFFFFF"
        android:textSize="10sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tv_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFA726"
        android:textSize="11sp"
        android:maxLines="2"
        android:layout_marginTop="4dp" />

</LinearLayout>
